' cyber.puml — local styling include for MedHub PlantUML diagrams.
'
' The plantuml skill mandates that every diagram begins with:
'   !include cyber.puml
'   !include sprites/all.sprite
'   skinparam linetype ortho
'
' In the broader toolchain `cyber.puml` provides shared theme/macros. This
' repo ships a minimal, self-contained version so the diagrams render here
' without external assets. Keep the diagrams' colour-tag convention:
'   #lightblue  = in-house components/items
'   #lightgray  = external / SOUP components
'   #lightgreen = (reserved) framework-native components

skinparam shadowing false
skinparam defaultFontName "Helvetica"
skinparam ArrowColor #404040
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #404040
}
skinparam database {
  BackgroundColor #FFFFFF
  BorderColor #404040
}
skinparam queue {
  BackgroundColor #FFFFFF
  BorderColor #404040
}
