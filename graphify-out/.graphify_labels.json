  "429": "3. Server-Side Performance (HIGH)",
  "430": "Slide Strategies",
  "431": "ADR-0001: Modular monolith with a runtime plugin/module mechanism",
  "432": "ADR-0002: Python + FastAPI for the backend",
  "433": "ADR-0003: TypeScript + React (Vite) responsive SPA",
  "434": "ADR-0004: PostgreSQL as the primary relational database",
  "435": "ADR-0005: Backend plugins via Python entry points; frontend modules via dynamic registration + lazy chunks",
  "436": "ADR-0006: Centralized deny-by-default RBAC plus per-source consent grants",
  "437": "ADR-0007: FHIR-aligned internal data model (FHIR R4), no full FHIR server in MVP",
  "438": "ADR-0008: DICOM stored as objects; viewing via Cornerstone3D in the browser",
  "439": "ADR-0009: S3-compatible object storage (MinIO) with server-side encryption",
  "440": "ADR-0010: Containerized single-tenant deployment via Docker Compose (MVP)",
  "441": "ADR-0011: Defense-in-depth security and compliance approach",
  "442": "ADR-0012: Server-side opaque session tokens in hardened cookies",
  "443": "ADR-0013: Account deletion via 5-year anonymized retention with a user-held retrieval code",
