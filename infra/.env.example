# MedHub environment configuration
# Copy this file to .env and fill in real values before starting services.
# NEVER commit the actual .env file to version control.

# ── Application ─────────────────────────────────────────────────────────────
# One of: local | staging | production
ENVIRONMENT=local

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# PostgreSQL connection string. Format: postgresql://user:password@host:port/db
DATABASE_URL=postgresql://medhub:changeme@postgres:5432/medhub

# ── Redis ────────────────────────────────────────────────────────────────────
# Used for sessions and as the Celery broker.
REDIS_URL=redis://redis:6379/0

# ── Object Store (MinIO / S3-compatible) ─────────────────────────────────────
# Endpoint URL for the S3-compatible object store.
OBJECT_STORE_ENDPOINT=http://minio:9000
# Access key ID (analogous to AWS_ACCESS_KEY_ID).
OBJECT_STORE_ACCESS_KEY=minioadmin
# Secret access key — treat this as a password.
OBJECT_STORE_SECRET_KEY=changeme
# Bucket name for attachments and DICOM files.
OBJECT_STORE_BUCKET=medhub

# ── Session Security ─────────────────────────────────────────────────────────
# Secret key used to sign session tokens. Must be at least 32 random bytes.
SESSION_SIGNING_KEY=change-me-to-a-random-32-byte-secret

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
# Port 587 = STARTTLS (recommended), 465 = SMTPS, 25 = plain (avoid)
SMTP_PORT=587
SMTP_USER=noreply@example.com
# SMTP account password.
SMTP_PASSWORD=changeme

# ── At-Rest Encryption ───────────────────────────────────────────────────────
# AES-256 key (32 bytes) used to encrypt PHI at rest. Rotate via key management.
AT_REST_ENCRYPTION_KEY=change-me-to-a-random-32-byte-key!

# ── Session Timeouts ─────────────────────────────────────────────────────────
# Inactivity timeout for clinical roles (DOCTOR, PATIENT) in seconds.
SESSION_INACTIVITY_CLINICAL_SECONDS=900
# Inactivity timeout for admin roles (ADMIN, SYSADMIN) in seconds.
SESSION_INACTIVITY_ADMIN_SECONDS=1800
# Absolute maximum session lifetime in seconds (8 hours).
SESSION_ABSOLUTE_LIFETIME_SECONDS=28800
# Maximum concurrent sessions per user before oldest is evicted.
SESSION_MAX_CONCURRENT=3

# ── Cookie / CSRF ─────────────────────────────────────────────────────────────
# Set to true in production (requires HTTPS). Set to false in local dev.
SESSION_COOKIE_SECURE=true

# ── SMTP extras ───────────────────────────────────────────────────────────────
# Use STARTTLS (port 587).
SMTP_USE_TLS=true
# Use implicit TLS (port 465); takes precedence over SMTP_USE_TLS if both are true.
SMTP_USE_SSL=false
# From address for outbound emails.
MAIL_FROM=noreply@example.com
# Public base URL for activation links etc.
PUBLIC_BASE_URL=https://medhub.example

# ── Retention ─────────────────────────────────────────────────────────────────
# Cron expression for the anonymized-dataset retention sweep (5-field cron).
RETENTION_SWEEP_CRON=0 2 * * *

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (empty = no CORS).
CORS_ORIGINS=
